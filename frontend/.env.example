# Uso: cp .env.example .env
#
# Al usar docker-compose desde la raiz del monorepo, este valor lo inyecta
# la variable VITE_API_BASE_URL del .env raiz (ver ../.env.example); este
# archivo solo aplica cuando se corre el frontend de forma standalone
# (npm run dev directamente, sin Docker).
VITE_API_BASE_URL=http://localhost:8000/api/v1
