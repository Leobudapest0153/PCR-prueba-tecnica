# Variables usadas por docker-compose.yml para levantar TODO el stack
# (backend, base de datos y frontend) con un solo comando.
#
# Uso: cp .env.example .env

# --- Puertos expuestos en el host ---
APP_PORT=8000
DB_FORWARD_PORT=5433
FRONTEND_PORT=5173

# --- Credenciales de la base de datos (compartidas por "db" y "app") ---
DB_DATABASE=pcr_prueba_tecnica
DB_USERNAME=pcr_user
DB_PASSWORD=pcr_password

# --- URLs cruzadas entre servicios ---
# Origen permitido por el backend para peticiones CORS del frontend.
FRONTEND_URL=http://localhost:5173
# URL de la API que usa el frontend (se resuelve desde el navegador, por
# eso apunta al puerto publicado en el host y no al nombre del servicio).
VITE_API_BASE_URL=http://localhost:8000/api/v1
